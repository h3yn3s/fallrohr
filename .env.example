# Directory for downloads and the JSON database
# DATA_DIR=/data

# Server port
# PORT=3000

# Public URL of the app (required by SvelteKit in production for CSRF protection)
# Set this to your actual URL if accessed remotely, e.g. https://fallrohr.example.com
# ORIGIN=http://localhost:3000

# Optional authentication (disabled when unset)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme
